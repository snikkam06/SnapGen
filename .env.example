# SnapGen Environment Variables (shared across all apps)
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snapgen
#
# Supabase Postgres example:
# DATABASE_URL must use the transaction pooler on port 6543 for runtime queries.
# DIRECT_URL must use the direct db host on port 5432 for migrations only.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snapgen
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/snapgen

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Clerk Auth ──
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY_HERE

# ── Email ──
RESEND_API_KEY=re_YOUR_KEY_HERE

# ── Cloudflare R2 Storage ──
R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
R2_BUCKET_UPLOADS=uploads-private
R2_BUCKET_OUTPUTS=outputs-private
R2_PUBLIC_BASE_URL=https://YOUR_R2_DOMAIN
STORAGE_MODE=r2
STORAGE_SIGNING_SECRET=

# ── AI Providers ──
GEMINI_API_KEY=
FAL_API_KEY=YOUR_FAL_KEY
REPLICATE_API_TOKEN=YOUR_REPLICATE_TOKEN
KLING_API_KEY=
IMAGE_PROVIDER=google
VIDEO_PROVIDER=fal
WORKER_REPLICAS=2
IMAGE_WORKER_CONCURRENCY=6
IMAGE_WORKER_LIMITER_MAX=30
VIDEO_WORKER_CONCURRENCY=3
VIDEO_WORKER_LIMITER_MAX=10
FACESWAP_WORKER_CONCURRENCY=3
FACESWAP_WORKER_LIMITER_MAX=10
POLL_WORKER_CONCURRENCY=20

# ── Per-User Limits ──
MAX_PENDING_JOBS_PER_USER=5

# ── Provider Concurrency Limits ──
FAL_CONCURRENCY_LIMIT=10
REPLICATE_CONCURRENCY_LIMIT=5
GOOGLE_CONCURRENCY_LIMIT=5

# ── Read Replica (optional, falls back to primary) ──
# DATABASE_READ_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION-read.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require

# ── Observability ──
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# ── URLs ──
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API Config ──
JWT_AUDIENCE=snapgen-api
PORT=3001

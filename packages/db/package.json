{
    "name": "@snapgen/db",
    "version": "0.1.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "db:generate": "prisma generate",
        "db:push": "node ../../scripts/with-database-url.mjs prisma db push",
        "db:migrate:deploy": "node ../../scripts/with-direct-url.mjs prisma migrate deploy",
        "db:seed": "node ../../scripts/with-database-url.mjs tsx src/seed.ts",
        "build": "pnpm db:generate && tsc",
        "clean": "rm -rf dist",
        "typecheck": "pnpm db:generate && tsc --noEmit",
        "lint": "echo 'no lint configured'"
    },
    "dependencies": {
        "@prisma/client": "^5.20.0"
    },
    "devDependencies": {
        "dotenv-cli": "^7.4.2",
        "prisma": "^5.20.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0"
    }
}

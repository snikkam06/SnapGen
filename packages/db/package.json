{
    "name": "@snapgen/db",
    "version": "0.1.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "db:generate": "DATABASE_URL=\"$(node ../../scripts/resolve-database-url.mjs)\" dotenv -e ../../apps/api/.env -- prisma generate",
        "db:push": "DATABASE_URL=\"$(node ../../scripts/resolve-database-url.mjs)\" dotenv -e ../../apps/api/.env -- prisma db push",
        "db:seed": "DATABASE_URL=\"$(node ../../scripts/resolve-database-url.mjs)\" dotenv -e ../../apps/api/.env -- tsx src/seed.ts",
        "build": "pnpm db:generate && tsc",
        "clean": "rm -rf dist",
        "typecheck": "pnpm db:generate && tsc --noEmit",
        "lint": "echo 'no lint configured'"
    },
    "dependencies": {
        "@prisma/client": "^5.20.0"
    },
    "devDependencies": {
        "dotenv-cli": "^7.4.2",
        "prisma": "^5.20.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0"
    }
}

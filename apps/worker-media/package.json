{
    "name": "@snapgen/worker-media",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@9.1.0",
    "scripts": {
        "dev": "pnpm run dev:single",
        "dev:single": "node ../../scripts/with-database-url.mjs dotenv -e ../api/.env -- tsx --watch src/index.ts",
        "dev:multi": "node scripts/start-multi.mjs --mode=dev",
        "build": "tsc",
        "start": "pnpm run start:multi",
        "start:single": "node ../../scripts/with-database-url.mjs dotenv -e ../api/.env -- node dist/index.js",
        "start:multi": "node scripts/start-multi.mjs --mode=start",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "lint": "echo 'no lint configured'"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.637.0",
        "@prisma/client": "^5.20.0",
        "@sentry/node": "^10.46.0",
        "@snapgen/config": "workspace:*",
        "@snapgen/db": "workspace:*",
        "@snapgen/media-adapters": "workspace:*",
        "@snapgen/types": "workspace:*",
        "bullmq": "^5.12.0",
        "dotenv": "^16.4.5",
        "ioredis": "^5.10.0"
    },
    "devDependencies": {
        "dotenv-cli": "^7.4.2",
        "prisma": "^5.20.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0"
    }
}

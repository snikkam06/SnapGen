{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --dir ../.. turbo run build --filter=@snapgen/worker-media",
    "watchPatterns": [
      "/apps/worker-media/**",
      "/packages/config/**",
      "/packages/db/**",
      "/packages/media-adapters/**",
      "/packages/types/**",
      "/scripts/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

# SnapGen API Environment Variables
# Local Postgres example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snapgen
#
# Supabase Postgres example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/snapgen
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/snapgen
REDIS_URL=redis://localhost:6379
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_KEY_HERE
RESEND_API_KEY=re_YOUR_KEY_HERE
R2_ACCOUNT_ID=YOUR_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
R2_BUCKET_UPLOADS=uploads-private
R2_BUCKET_OUTPUTS=outputs-private
R2_PUBLIC_BASE_URL=https://YOUR_R2_DOMAIN
FAL_API_KEY=YOUR_FAL_KEY
REPLICATE_API_TOKEN=YOUR_REPLICATE_TOKEN
SENTRY_DSN=
POSTHOG_API_KEY=
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
JWT_AUDIENCE=snapgen-api
PORT=3001

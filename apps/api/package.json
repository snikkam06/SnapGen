{
    "name": "@snapgen/api",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "DATABASE_URL=\"$(node ../../scripts/resolve-database-url.mjs)\" nest start --watch --port 3001",
        "build": "nest build",
        "start": "DATABASE_URL=\"$(node ../../scripts/resolve-database-url.mjs)\" node dist/main",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@nestjs/common": "^10.4.0",
        "@nestjs/core": "^10.4.0",
        "@nestjs/platform-express": "^10.4.0",
        "@nestjs/swagger": "^7.4.0",
        "@nestjs/throttler": "^6.0.0",
        "@nestjs/bullmq": "^10.2.0",
        "@prisma/client": "^5.20.0",
        "bullmq": "^5.12.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "ioredis": "^5.4.0",
        "jwks-rsa": "^3.1.0",
        "jsonwebtoken": "^9.0.2",
        "stripe": "^16.12.0",
        "@aws-sdk/client-s3": "^3.637.0",
        "@aws-sdk/s3-request-presigner": "^3.637.0",
        "dotenv": "^16.4.5",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "@snapgen/types": "workspace:*",

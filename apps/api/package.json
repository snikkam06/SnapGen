        "@snapgen/media-adapters": "workspace:*"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.0",
        "@nestjs/schematics": "^10.1.0",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^22.0.0",
        "prisma": "^5.20.0",
        "typescript": "^5.5.0"
